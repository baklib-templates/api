<!DOCTYPE html>
<html class="scroll-smooth bg-base-100" lang="{{ site.language }}">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% meta_tags %}

    {% render 'theme_runtime_colors' %}

    {{ 'stylesheets/application.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
  </head>
  <body class="bg-base-100 text-base-content antialiased">
    <div class="page-container py-20 text-center">
      {{ content_for_layout }}
    </div>
  </body>
</html>
