<!DOCTYPE html>
<html class="scroll-smooth bg-base-100" lang="{{ site.language }}">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="author" content="Baklib">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% meta_tags %}

    {% render 'theme_runtime_colors' %}

    {{ 'css/styles.min.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'stylesheets/application.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'javascripts/web-components.min.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
    {{ 'javascripts/application.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}

    {{ site.settings.head_html }}
  </head>
  <body id="js-body" class="flex min-h-screen flex-col bg-base-100 text-base-content antialiased">
    {% render 'header' %}

    <main class="relative flex min-h-0 flex-1 flex-col bg-base-100 pt-16">
      {{ content_for_layout }}
    </main>
  </body>
</html>
