<header
  id="header"
  class="fixed inset-x-0 top-0 z-50 flex w-full min-h-16 items-center border-b border-base-300 bg-base-100/95 text-base-content backdrop-blur supports-[backdrop-filter]:bg-base-100/80"
>
  <nav class="page-container navbar min-h-16 w-full px-2 md:pr-12">
    <div class="navbar-start">
      <a href="{{ site.index_path }}" class="btn btn-ghost px-2">
        <span class="flex items-center gap-3 text-xl font-bold md:text-2xl">
          {% assign logo = 'images/logo.png' | asset_url %}
          <span class="flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden rounded-field border border-base-300 bg-base-200">
            <img
              src="{{ site.favicon_url | default: logo }}"
              alt=""
              class="max-h-full max-w-full object-contain"
              onerror="this.onerror=null;this.src='{{ logo }}';"
            >
          </span>
          <span class="hidden sm:inline">{{ site.name }}</span>
        </span>
      </a>

      {% if site.settings.header_menu_html != blank %}
        <div class="hidden border-l border-base-300 lg:flex [&_a]:px-3 [&_a]:text-sm [&_a]:font-medium [&_a]:text-base-content/70 [&_a]:hover:text-accent">
          {{ site.settings.header_menu_html }}
        </div>
      {% endif %}
    </div>

    <div class="navbar-end gap-1">
      <div>
        {% if site.settings.header_menu_html != blank %}
          {{ site.settings.header_menu_html }}
        {% else %}
          <a href="/s/about">About</a>
        {% endif %}
      </div>

      {% if current_user %}
        <details class="dropdown dropdown-bottom">
          <summary class="btn btn-ghost m-1">{{ current_user.name }}</summary>
          <ul class="menu dropdown-content z-[1] w-52 rounded-box bg-base-300 p-2 shadow">
            {% if current_user.image %}
              <li>
                <div class="flex items-center gap-2">
                  <span class="flex h-6 w-6 shrink-0 overflow-hidden rounded-full">
                    <img src="{{ current_user.image }}" class="h-full w-full object-cover" alt="">
                  </span>
                  <span>{{ current_user.name }}</span>
                </div>
              </li>
            {% endif %}
            <li>
              {% form_tag 'sign_out' %}
                <button type="submit" class="flex w-full items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
                  </svg>
                  <span>{{ 'generic.sign_out' | t }}</span>
                </button>
              {% endform_tag %}
            </li>
          </ul>
        </details>
      {% endif %}
    </div>
  </nav>
</header>
